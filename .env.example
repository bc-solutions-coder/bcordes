# ===========================================
# Production Environment Variables (bcordes web)
# Copy to .env and fill in real values
# Wallow API + Postgres are stood up separately
# ===========================================

# Valkey (session store — password shared with valkey container)
VALKEY_PASSWORD=CHANGE_ME
VALKEY_URL=redis://default:CHANGE_ME@valkey:6379

# Frontend
WALLOW_API_URL=https://api.wallow.dev
SESSION_SECRET=CHANGE_ME_AT_LEAST_64_CHARS

# OIDC (authorization code + PKCE — OpenIddict on Wallow)
OIDC_ISSUER=https://api.wallow.dev
OIDC_CLIENT_ID=bcordes-dev-client
OIDC_CLIENT_SECRET=CHANGE_ME
OIDC_REDIRECT_URI=https://bcordes.dev/auth/callback

# Service Account (M2M — client credentials grant, sa- prefix)
OIDC_SERVICE_CLIENT_ID=sa-bcordes-bff
OIDC_SERVICE_CLIENT_SECRET=CHANGE_ME
